<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="YellowInside.ManageWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:YellowInside"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:winuiex="using:WinUIEx"
    Title="옐로우 인사이드"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon
            x:Name="TaskbarIcon"
            ContextMenuMode="SecondWindow"
            MenuActivation="RightClick"
            NoLeftClickDelay="True"
            ToolTipText="옐로우 인사이드">
            <tb:TaskbarIcon.IconSource>
                <tb:GeneratedIconSource BackgroundSource="ms-appx:///Assets/Icon.png" />
            </tb:TaskbarIcon.IconSource>
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout AreOpenCloseAnimationsEnabled="True">
                    <MenuFlyoutItem IsEnabled="False" Text="제작자: 이호원 (airtaxi)" />
                    <MenuFlyoutItem x:Name="OpenManageWindowMenuFlyoutItem" Text="관리 창 열기" />
                    <MenuFlyoutItem
                        x:Name="LaunchOnStartupMenuFlyoutItem"
                        Click="OnLaunchOnStartupMenuFlyoutItemClicked"
                        Text="시스템 시작 시 자동 실행 설정" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Click="OnCloseProgramMenuFlyoutItemClicked" Text="프로그램 종료" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <TitleBar
            x:Name="AppTitleBar"
            Title="옐로우 인사이드"
            Grid.Row="0"
            BackRequested="OnAppTitleBarBackRequested"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="OnAppTitleBarPaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Icon.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="AppFrame" Grid.Row="1" />

        <Grid
            x:Name="LoadingGrid"
            Grid.RowSpan="2"
            Visibility="Collapsed">
            <Grid.Background>
                <AcrylicBrush Opacity="0.5" TintColor="{ThemeResource LayerOnMicaBaseAltFillColorDefault}" />
            </Grid.Background>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <ProgressRing
                    Width="80"
                    Height="80"
                    IsIndeterminate="True" />
                <TextBlock
                    x:Name="LoadingTextBlock"
                    HorizontalAlignment="Center"
                    FontWeight="Bold" />
            </StackPanel>
        </Grid>
    </Grid>
</winuiex:WindowEx>
