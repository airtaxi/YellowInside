<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="YellowInside.Pages.ManagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:YellowInside.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <SelectorBar
            Grid.Row="0"
            SelectedItem="{x:Bind SelectorBarItemHome}"
            SelectionChanged="OnSelectorBarSelectionChanged">
            <SelectorBarItem x:Name="SelectorBarItemHome" Text="홈">
                <SelectorBarItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="SearchSelectorBarItem" Text="검색">
                <SelectorBarItem.Icon>
                    <SymbolIcon Symbol="Find" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="SubscriptionsSelectorBarItem" Text="구독">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xEA8F;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="SelectorBarItemFavorites" Text="즐겨찾기">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE728;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="SelectorBarItemSettings" Text="설정">
                <SelectorBarItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
        </SelectorBar>

        <Frame x:Name="ContentFrame" Grid.Row="1" />
    </Grid>
</Page>
