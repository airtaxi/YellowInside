<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="YellowInside.Pages.DetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:YellowInside.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:YellowInside.ViewModels"
    Padding="12,8,12,12"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:DetailViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Padding="12" Spacing="16">
            <!--  페이지 헤더  -->
            <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="{x:Bind ViewModel.HeaderText, Mode=OneWay}" />

            <!--  패키지 정보 카드  -->
            <Grid
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                ColumnSpacing="12"
                CornerRadius="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  대표 이미지  -->
                <Border
                    Grid.Column="0"
                    Width="200"
                    Height="200"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="6">
                    <Image Source="{x:Bind ViewModel.MainImageSource, Mode=OneWay}" Stretch="Uniform" />
                </Border>

                <!--  메타데이터  -->
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Spacing="4">
                    <TextBlock
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,-2,0,0"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind ViewModel.SellerName, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        MaxLines="4"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  구독 (온라인 소스)  -->
                <Grid
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Visibility="{x:Bind ViewModel.IsLocalPackage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}">
                    <Button
                        Command="{x:Bind ViewModel.SubscribeCommand}"
                        ToolTipService.ToolTip="구독"
                        Visibility="{x:Bind ViewModel.IsSubscribed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}">
                        <FontIcon Glyph="&#xEA8F;" />
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.UnsubscribeCommand}"
                        ToolTipService.ToolTip="구독 해제"
                        Visibility="{x:Bind ViewModel.IsSubscribed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <FontIcon Glyph="&#xE7ED;" />
                    </Button>
                </Grid>

                <!--  수정 / 삭제 (사용자 지정콘)  -->
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Spacing="4"
                    Visibility="{x:Bind ViewModel.IsLocalPackage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button
                        Command="{x:Bind ViewModel.EditCommand}"
                        ToolTipService.ToolTip="수정">
                        <FontIcon Glyph="&#xE70F;" />
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.UnsubscribeCommand}"
                        ToolTipService.ToolTip="삭제">
                        <FontIcon Glyph="&#xE74D;" />
                    </Button>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Spacing="2">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.IconCount, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.SaleCount, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.RegisterationDate, Mode=OneWay}" />
                    <!--  태그  -->
                    <ItemsRepeater Margin="0,6,0,0" ItemsSource="{x:Bind ViewModel.Tags, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="6" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border
                                    Padding="8,3"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="12">
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind}" />
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </Grid>

            <!--  스티커 섹션  -->
            <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="스티커" />
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Stickers, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MinColumnSpacing="8"
                        MinItemHeight="96"
                        MinItemWidth="96"
                        MinRowSpacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:StickerViewModel">
                        <Border
                            Width="96"
                            Height="96"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="6">
                            <Grid>
                                <!--  Image  -->
                                <Image Source="{x:Bind ImageSource, Mode=OneWay}" Stretch="Uniform" />

                                <!--  Favorite Zone  -->
                                <Grid
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Visibility="{x:Bind IsSubscribed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                                    <!--  Favorite Border  -->
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Foreground="Black"
                                        Glyph="&#xE735;"
                                        Tapped="{x:Bind OnFavoriteSymbolIconTapped}" />

                                    <!--  Favorite  -->
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="LightGray"
                                        Glyph="&#xE735;"
                                        IsHitTestVisible="False" />

                                    <!--  Unfavorite  -->
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="Gold"
                                        Glyph="&#xE735;"
                                        IsHitTestVisible="False"
                                        Visibility="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
</Page>
