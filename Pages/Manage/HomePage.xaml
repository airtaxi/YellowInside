<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="YellowInside.Pages.Manage.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:YellowInside.Pages.Manage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid>
        <Grid.Resources>
            <TeachingTip
                x:Name="ContentSourceSupportTeachingTip"
                Title="아카콘과 인벤 스티커 지원 추가"
                ActionButtonClick="OnContentSourceSupportTeachingTipActionButtonClicked"
                ActionButtonContent="확인"
                PreferredPlacement="Bottom"
                Subtitle="이제 홈 페이지와 검색 페이지에서도 아카콘과 인벤 스티커를 사용할 수 있어요." />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <SelectorBar
            x:Name="ContentSourceSelectorBar"
            Grid.Row="0"
            SelectedItem="{x:Bind DcconSelectorBarItem}"
            SelectionChanged="OnSelectorBarSelectionChanged">
            <SelectorBarItem x:Name="DcconSelectorBarItem" Text="디시콘" />
            <SelectorBarItem x:Name="ArcaconSelectorBarItem" Text="아카콘" />
            <SelectorBarItem x:Name="InvenStickerSelectorBarItem" Text="인벤 스티커" />
        </SelectorBar>
        <Frame x:Name="ContentFrame" Grid.Row="1" />
    </Grid>
</Page>
