<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="YellowInside.Pages.Manage.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:YellowInside.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:YellowInside.Pages.Manage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:YellowInside.ViewModels"
    DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="4">
            <Grid>
                <Button
                    Grid.Row="0"
                    Margin="0,0,12,0"
                    Padding="8"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Click="OnRefreshButtonClicked">
                    <SymbolIcon Symbol="Refresh" />
                </Button>
                <TextBlock
                    Grid.Row="0"
                    Margin="12,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="일간 인기 디시콘" />
            </Grid>
            <ScrollView
                Grid.Row="1"
                Height="112"
                ContentOrientation="Horizontal"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalScrollMode="Enabled"
                PointerWheelChanged="OnScrollViewPointerWheelChanged">
                <ItemsRepeater Margin="8" ItemsSource="{x:Bind DailyPopularList}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchResultViewModel">
                            <Button
                                Width="260"
                                Padding="0"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="{x:Bind OnClicked}"
                                CornerRadius="8">
                                <controls:CardControl
                                    Title="{x:Bind Title}"
                                    Description="{x:Bind SellerName}"
                                    Tags="{x:Bind Tags, Mode=OneWay}"
                                    ThumbnailSource="{x:Bind ThumbnailSource, Mode=OneWay}" />
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollView>

            <TextBlock
                Grid.Row="0"
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="주간 인기 디시콘" />
            <ScrollView
                Grid.Row="1"
                Height="112"
                ContentOrientation="Horizontal"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalScrollMode="Enabled"
                PointerWheelChanged="OnScrollViewPointerWheelChanged">
                <ItemsRepeater Margin="8" ItemsSource="{x:Bind WeeklyPopularList}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchResultViewModel">
                            <Button
                                Width="260"
                                Padding="0"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="{x:Bind OnClicked}"
                                CornerRadius="8">
                                <controls:CardControl
                                    Title="{x:Bind Title}"
                                    Description="{x:Bind SellerName}"
                                    Tags="{x:Bind Tags, Mode=OneWay}"
                                    ThumbnailSource="{x:Bind ThumbnailSource, Mode=OneWay}" />
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollView>

            <TextBlock
                Grid.Row="0"
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="인기 디시콘" />
            <ScrollView
                Grid.Row="1"
                Height="112"
                ContentOrientation="Horizontal"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalScrollMode="Enabled"
                PointerWheelChanged="OnScrollViewPointerWheelChanged"
                Tag="Hot"
                ViewChanged="OnScrollViewViewChanged">
                <ItemsRepeater Margin="8" ItemsSource="{x:Bind HotList}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchResultViewModel">
                            <Button
                                Width="260"
                                Padding="0"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="{x:Bind OnClicked}"
                                CornerRadius="8">
                                <controls:CardControl
                                    Title="{x:Bind Title}"
                                    Description="{x:Bind SellerName}"
                                    Tags="{x:Bind Tags, Mode=OneWay}"
                                    ThumbnailSource="{x:Bind ThumbnailSource, Mode=OneWay}" />
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollView>

            <TextBlock
                Grid.Row="2"
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="최신 디시콘" />
            <ScrollView
                Grid.Row="3"
                Height="112"
                ContentOrientation="Horizontal"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalScrollMode="Enabled"
                PointerWheelChanged="OnScrollViewPointerWheelChanged"
                Tag="New"
                ViewChanged="OnScrollViewViewChanged">
                <ItemsRepeater Margin="8" ItemsSource="{x:Bind NewList}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchResultViewModel">
                            <Button
                                Width="260"
                                Padding="0"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="{x:Bind OnClicked}"
                                CornerRadius="8">
                                <controls:CardControl
                                    Title="{x:Bind Title}"
                                    Description="{x:Bind SellerName}"
                                    Tags="{x:Bind Tags, Mode=OneWay}"
                                    ThumbnailSource="{x:Bind ThumbnailSource, Mode=OneWay}" />
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollView>
        </StackPanel>
    </ScrollViewer>
</Page>
