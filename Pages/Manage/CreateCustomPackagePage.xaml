<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="YellowInside.Pages.Manage.CreateCustomPackagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:YellowInside.Pages.Manage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <TextBlock
            Grid.Row="0"
            Padding="20,12,20,8"
            Style="{ThemeResource TitleTextBlockStyle}"
            Text="사용자 지정콘 추가" />

        <!--  Content  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Hidden">
            <StackPanel Padding="20,4,20,20" Spacing="16">

                <!--  제목  -->
                <TextBox
                    x:Name="TitleTextBox"
                    Header="제목"
                    PlaceholderText="패키지 제목을 입력하세요"
                    TextChanged="OnTitleTextBoxTextChanged" />

                <!--  설명  -->
                <TextBox
                    x:Name="DescriptionTextBox"
                    MaxHeight="120"
                    AcceptsReturn="True"
                    Header="설명"
                    PlaceholderText="패키지 설명을 입력하세요 (선택)"
                    TextWrapping="Wrap" />

                <!--  대표 이미지  -->
                <StackPanel Spacing="8">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="대표 이미지" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            Width="80"
                            Height="80"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="8">
                            <Image
                                x:Name="MainImagePreview"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Stretch="Uniform" />
                        </Border>
                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="8">
                            <Button Click="OnSelectMainImageButtonClicked" Content="이미지 선택..." />
                            <TextBlock
                                x:Name="MainImageFileNameTextBlock"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="선택된 이미지 없음"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!--  제작자 이름  -->
                <TextBox
                    x:Name="SellerNameTextBox"
                    Header="제작자 이름"
                    PlaceholderText="제작자 이름을 입력하세요 (선택)" />

                <!--  등록일  -->
                <TextBox
                    x:Name="RegistrationDateTextBox"
                    Foreground="{ThemeResource TextFillColorDisabledBrush}"
                    Header="등록일"
                    IsReadOnly="True" />

                <!--  태그  -->
                <StackPanel Spacing="8">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="태그" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="TagInputTextBox"
                            Grid.Column="0"
                            KeyDown="OnTagInputTextBoxKeyDown"
                            PlaceholderText="태그를 입력 후 Enter 또는 추가 버튼" />
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Click="OnAddTagButtonClicked"
                            Content="추가" />
                    </Grid>
                    <ItemsRepeater x:Name="TagsRepeater" ItemsSource="{x:Bind Tags}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="6" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border
                                    Padding="8,4"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="12">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Text="{x:Bind}" />
                                        <Button
                                            Width="20"
                                            Height="20"
                                            MinWidth="20"
                                            MinHeight="20"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Click="OnRemoveTagButtonClicked"
                                            Tag="{x:Bind}">
                                            <FontIcon FontSize="10" Glyph="&#xE711;" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!--  스티커  -->
                <StackPanel Spacing="8">
                    <Grid>
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="스티커" />
                            <TextBlock
                                x:Name="StickerCountTextBlock"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="0개" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Click="OnAddStickersButtonClicked">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE8B9;" />
                                <TextBlock Text="이미지 추가..." />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListView
                        x:Name="StickersListView"
                        MaxHeight="400"
                        AllowDrop="True"
                        CanDragItems="True"
                        CanReorderItems="True"
                        ItemsSource="{x:Bind StickerFiles}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:StickerFileItem">
                                <Grid Height="56" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Glyph="&#xE700;" />
                                    <Border
                                        Grid.Column="1"
                                        Width="48"
                                        Height="48"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="4">
                                        <Image Source="{x:Bind Thumbnail}" Stretch="Uniform" />
                                    </Border>
                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind DisplayName}"
                                        TextTrimming="CharacterEllipsis" />
                                    <Button
                                        Grid.Column="3"
                                        Width="32"
                                        Height="32"
                                        MinWidth="32"
                                        MinHeight="32"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Click="OnRemoveStickerButtonClicked"
                                        ToolTipService.ToolTip="제거">
                                        <FontIcon FontSize="12" Glyph="&#xE711;" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock
                        x:Name="NoStickersTextBlock"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="등록된 스티커가 없습니다. '이미지 추가' 버튼으로 스티커를 추가하세요." />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!--  Bottom bar  -->
        <Border
            Grid.Row="2"
            Padding="20,12"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Button
                    HorizontalAlignment="Left"
                    Click="OnCancelButtonClicked"
                    Content="취소" />
                <Button
                    x:Name="SaveButton"
                    HorizontalAlignment="Right"
                    Click="OnSaveButtonClicked"
                    Content="저장"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Page>
