<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="YellowInside.Pages.Manage.CustomPackagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:YellowInside.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:YellowInside.ViewModels"
    xmlns:wct="using:CommunityToolkit.WinUI.Controls"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid Padding="12,12,12,0" RowSpacing="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="사용자 지정콘" />
            <Button
                Margin="0,0,12,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="OnAddCustomPackageButtonClicked">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock Text="추가" />
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <ItemsRepeater Margin="0,0,0,12" ItemsSource="{x:Bind CustomPackageList}">
                <ItemsRepeater.Layout>
                    <wct:StaggeredLayout
                        ColumnSpacing="8"
                        DesiredColumnWidth="260"
                        ItemsStretch="Fill"
                        RowSpacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:SubscriptionViewModel">
                        <Button
                            Padding="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="{x:Bind OnClicked}"
                            CornerRadius="8">
                            <controls:CardControl
                                Title="{x:Bind Title}"
                                Description="{x:Bind SellerName}"
                                Tags="{x:Bind Tags, Mode=OneWay}"
                                ThumbnailSource="{x:Bind ThumbnailSource, Mode=OneWay}" />
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <TextBlock
            x:Name="NoCustomPackagesTextBlock"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{ThemeResource BodyTextBlockStyle}"
            Text="사용자 지정콘이 없습니다. '추가' 버튼을 눌러 새 패키지를 만들어 보세요."
            Visibility="Collapsed" />
    </Grid>
</Page>
