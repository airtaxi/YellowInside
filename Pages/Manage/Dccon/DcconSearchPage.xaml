<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="YellowInside.Pages.Manage.Dccon.DcconSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:YellowInside.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:YellowInside.Pages.Manage.Dccon"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:YellowInside.ViewModels"
    xmlns:wct="using:CommunityToolkit.WinUI.Controls"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Margin="12,8,12,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AutoSuggestBox
                x:Name="SearchAutoSuggestBox"
                Grid.Column="0"
                PlaceholderText="디시콘 검색..."
                QueryIcon="Find"
                QuerySubmitted="OnSearchAutoSuggestBoxQuerySubmitted" />

            <ComboBox
                x:Name="SearchTypeComboBox"
                Grid.Column="1"
                MinWidth="100"
                SelectedIndex="0">
                <ComboBoxItem Content="디시콘명" Tag="Title" />
                <ComboBoxItem Content="닉네임" Tag="NickName" />
                <ComboBoxItem Content="태그" Tag="Tags" />
            </ComboBox>

            <ComboBox
                x:Name="SearchSortComboBox"
                Grid.Column="2"
                MinWidth="90"
                SelectedIndex="0">
                <ComboBoxItem Content="인기순" Tag="Hot" />
                <ComboBoxItem Content="최신순" Tag="New" />
            </ComboBox>
        </Grid>

        <Grid Grid.Row="1">
            <TextBlock
                x:Name="NoResultTextBlock"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="검색 결과가 없습니다"
                Visibility="Collapsed" />

            <ScrollViewer
                x:Name="ResultScrollViewer"
                SizeChanged="OnResultScrollViewerSizeChanged"
                ViewChanged="OnResultScrollViewerViewChanged"
                Visibility="Collapsed">
                <ItemsRepeater Margin="8" ItemsSource="{x:Bind SearchResultList}">
                    <ItemsRepeater.Layout>
                        <wct:StaggeredLayout
                            ColumnSpacing="8"
                            DesiredColumnWidth="260"
                            ItemsStretch="Fill"
                            RowSpacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchResultViewModel">
                            <Button
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="{x:Bind OnClicked}"
                                CornerRadius="8">
                                <controls:CardControl
                                    Title="{x:Bind Title}"
                                    Description="{x:Bind SellerName}"
                                    Tags="{x:Bind Tags, Mode=OneWay}"
                                    ThumbnailSource="{x:Bind ThumbnailSource, Mode=OneWay}" />
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
