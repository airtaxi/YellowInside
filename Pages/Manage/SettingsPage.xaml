<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="YellowInside.Pages.Manage.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="4">

            <!--  외관  -->
            <TextBlock
                Margin="4,0,0,4"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="외관" />
            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Spacing="2">
                        <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="테마" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="앱의 색상 테마를 설정합니다." />
                    </StackPanel>
                    <ComboBox
                        x:Name="ThemeComboBox"
                        Grid.Column="1"
                        MinWidth="160"
                        VerticalAlignment="Center"
                        SelectionChanged="OnThemeComboBoxSelectionChanged">
                        <ComboBoxItem Content="시스템 테마" Tag="System" />
                        <ComboBoxItem Content="라이트 모드" Tag="Light" />
                        <ComboBoxItem Content="다크 모드" Tag="Dark" />
                    </ComboBox>
                </Grid>
            </Border>

            <!--  재생  -->
            <TextBlock
                Margin="4,20,0,4"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="재생" />
            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Spacing="2">
                        <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="GIF 재생" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="스티커 미리보기에서 GIF 애니메이션을 재생합니다." />
                        <InfoBar
                            x:Name="GifWarningInfoBar"
                            Margin="0,8,0,0"
                            CornerRadius="8"
                            IsClosable="False"
                            IsOpen="False"
                            Message="GIF 재생을 활성화하면 GIF를 재생하는 동안 CPU 사용량이 매우 높아질 수 있습니다."
                            Severity="Warning" />
                    </StackPanel>
                    <ToggleSwitch
                        x:Name="GifPlaybackToggleSwitch"
                        Grid.Column="1"
                        MinWidth="0"
                        VerticalAlignment="Top"
                        OffContent="끔"
                        OnContent="켬"
                        Toggled="OnGifPlaybackToggleSwitchToggled" />
                </Grid>
            </Border>

            <!--  단축키  -->
            <TextBlock
                Margin="4,20,0,4"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="단축키" />
            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="빠른 실행 단축키" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="단축키를 눌러 활성 창에 디시콘 팝업을 엽니다." />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="HotkeyToggleSwitch"
                            Grid.Column="1"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            OffContent="끔"
                            OnContent="켬"
                            Toggled="OnHotkeyToggleSwitchToggled" />
                    </Grid>
                    <Border
                        x:Name="HotkeyDivider"
                        Height="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Visibility="Collapsed" />
                    <Grid
                        x:Name="HotkeySettingGrid"
                        ColumnSpacing="16"
                        Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            x:Name="HotkeyDisplayPanel"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4" />
                        <Button
                            x:Name="ChangeHotkeyButton"
                            Grid.Column="1"
                            MinWidth="80"
                            VerticalAlignment="Center"
                            Click="OnChangeHotkeyButtonClicked"
                            Content="변경" />
                    </Grid>
                </StackPanel>
            </Border>

            <!--  시스템  -->
        <TextBlock
            Margin="4,20,0,4"
            Style="{ThemeResource BodyStrongTextBlockStyle}"
            Text="시스템" />
        <Border
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Spacing="2">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="시스템 시작 시 자동 실행" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Windows 시작 시 프로그램을 자동으로 실행합니다." />
                </StackPanel>
                <ToggleSwitch
                    x:Name="LaunchOnStartupToggleSwitch"
                    Grid.Column="1"
                    MinWidth="0"
                    VerticalAlignment="Center"
                    OffContent="끔"
                    OnContent="켬"
                    Toggled="OnLaunchOnStartupToggleSwitchToggled" />
            </Grid>
        </Border>

        <!--  업데이트  -->
            <TextBlock
                Margin="4,20,0,4"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="업데이트" />
            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Spacing="2">
                        <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="업데이트 확인" />
                        <TextBlock
                            x:Name="UpdateStatusTextBlock"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Microsoft Store에서 업데이트를 확인합니다." />
                    </StackPanel>
                    <Button
                        x:Name="CheckUpdateButton"
                        Grid.Column="1"
                        MinWidth="120"
                        VerticalAlignment="Center"
                        Click="OnCheckUpdateButtonClicked"
                        Content="확인하기" />
                </Grid>
            </Border>

        <!--  데이터 관리  -->
            <TextBlock
                Margin="4,20,0,4"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="데이터 관리" />
            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="패키지 내보내기" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="다운로드된 패키지와 즐겨찾기를 .yip 파일로 내보냅니다." />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            MinWidth="120"
                            VerticalAlignment="Center"
                            Click="OnExportButtonClicked"
                            Content="내보내기" />
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="패키지 불러오기" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text=".yip 파일에서 패키지와 즐겨찾기를 불러옵니다." />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            MinWidth="120"
                            VerticalAlignment="Center"
                            Click="OnImportButtonClicked"
                            Content="불러오기" />
                    </Grid>
                </StackPanel>
            </Border>

            <!--  전송 설정 관리  -->
            <TextBlock
                Margin="4,20,0,4"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="전송 설정 관리" />
            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="전송 설정 내보내기" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="앱별 전송 방식 설정을 .yic 파일로 내보냅니다." />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            MinWidth="120"
                            VerticalAlignment="Center"
                            Click="OnExportSendMethodButtonClicked"
                            Content="내보내기" />
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="전송 설정 불러오기" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text=".yic 파일에서 앱별 전송 방식 설정을 불러옵니다." />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            MinWidth="120"
                            VerticalAlignment="Center"
                            Click="OnImportSendMethodButtonClicked"
                            Content="불러오기" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
