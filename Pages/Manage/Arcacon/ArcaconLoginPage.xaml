<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="YellowInside.Pages.Manage.Arcacon.ArcaconLoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:YellowInside.Pages.Manage.Arcacon"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="아카콘 로그인" />

        <TextBlock
            Grid.Row="1"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="아카라이브 로그인 후 자동으로 원래 페이지로 돌아갑니다."
            TextWrapping="Wrap" />

        <WebView2
            x:Name="LoginWebView2"
            Grid.Row="2"
            MinHeight="420" />

        <Grid Grid.Row="3" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressRing
                x:Name="LoginProgressRing"
                Grid.Column="0"
                Width="20"
                Height="20"
                IsActive="False" />

            <TextBlock
                x:Name="StatusTextBlock"
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="로그인 페이지를 준비하는 중..."
                TextWrapping="Wrap" />

            <Button
                x:Name="RetryButton"
                Grid.Column="2"
                Click="OnRetryButtonClicked"
                Content="다시 시도" />
        </Grid>
    </Grid>
</Page>
