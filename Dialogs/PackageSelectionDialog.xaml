<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="YellowInside.Dialogs.PackageSelectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:YellowInside.ViewModels"
    CloseButtonText="취소"
    DefaultButton="Primary"
    Style="{ThemeResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <StackPanel Spacing="12">
        <TextBlock x:Name="InstructionTextBlock" TextWrapping="Wrap" />
        <ListView
            x:Name="PackageListView"
            MaxHeight="420"
            IsMultiSelectCheckBoxEnabled="True"
            ItemsSource="{x:Bind PackageItems, Mode=OneWay}"
            SelectionChanged="OnPackageListViewSelectionChanged"
            SelectionMode="Multiple">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="10" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PackageSelectionListViewModel">
                    <Grid Height="56" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="4">
                            <Image
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                Stretch="Uniform" />
                        </Border>
                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock
                                FontWeight="SemiBold"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="{x:Bind Title}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="{x:Bind SellerName}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
