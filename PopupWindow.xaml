<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="YellowInside.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
Closed="OnClosed"
    xmlns:vm="using:YellowInside.ViewModels"
    xmlns:winuiex="using:WinUIEx"
    Title="이모티콘 선택"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  헤더  -->
        <Grid Grid.Row="0">
            <TextBlock
                VerticalAlignment="Center"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="디시콘" />
            <Button
                Padding="8"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Click="OnCloseButtonClicked"
                ToolTipService.ToolTip="닫기">
                <FontIcon FontSize="12" Glyph="&#xE711;" />
            </Button>
        </Grid>

        <!--  카테고리 목록  -->
        <GridView
            x:Name="CategoryGridView"
            Grid.Row="1"
            MaxHeight="84"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.Categories}"
            SelectionChanged="OnCategoryGridViewSelectionChanged"
            SelectionMode="Single">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="2" />
                    <Setter Property="Padding" Value="2" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="vm:PopupCategoryViewModel">
                    <Grid
                        Width="32"
                        Height="32"
                        ToolTipService.ToolTip="{x:Bind Title}">
                        <FontIcon
                            FontSize="18"
                            Glyph="&#xE734;"
                            Visibility="{x:Bind FavoriteIconVisibility}" />
                        <Image
                            Source="{x:Bind ThumbnailSource}"
                            Stretch="Uniform"
                            Visibility="{x:Bind ThumbnailVisibility}" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!--  구분선  -->
        <Border
            Grid.Row="2"
            Height="1"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!--  스티커 그리드  -->
        <GridView
            x:Name="StickerGridView"
            Grid.Row="3"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.Stickers, Mode=OneWay}"
            SelectionMode="None">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="4" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="vm:PopupStickerViewModel">
                    <Button
                        Width="80"
                        Height="80"
                        Padding="0"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        Command="{x:Bind SendCommand}"
                        CornerRadius="6"
                        ToolTipService.ToolTip="{x:Bind Title}">
                        <Grid Width="72" Height="72">
                            <Image Source="{x:Bind ImageSource}" Stretch="Uniform" />

                            <!--  즐겨찾기 토글  -->
                            <Button
                                Width="18"
                                Height="18"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{x:Bind ToggleFavoriteCommand}">
                                <Grid>
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Foreground="Black"
                                        Glyph="&#xE735;" />
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="LightGray"
                                        Glyph="&#xE735;"
                                        IsHitTestVisible="False" />
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="Gold"
                                        Glyph="&#xE735;"
                                        IsHitTestVisible="False"
                                        Visibility="{x:Bind FavoriteIconVisibility, Mode=OneWay}" />
                                </Grid>
                            </Button>
                        </Grid>
                    </Button>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</winuiex:WindowEx>
