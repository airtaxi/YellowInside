<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="YellowInside.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:YellowInside.ViewModels"
    xmlns:winuiex="using:WinUIEx"
    Title="이모티콘 선택"
    Closed="OnClosed"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  헤더  -->
        <Grid Grid.Row="0">
            <TextBlock
                VerticalAlignment="Center"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="디시콘" />
            <Button
                Padding="8"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Click="OnCloseButtonClicked"
                ToolTipService.ToolTip="닫기">
                <FontIcon FontSize="12" Glyph="&#xE711;" />
            </Button>
        </Grid>

        <!--  카테고리 목록  -->
        <GridView
            x:Name="CategoryGridView"
            Grid.Row="1"
            MaxHeight="60"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.Categories}"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SelectionChanged="OnCategoryGridViewSelectionChanged"
            SelectionMode="Single">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="2" />
                    <Setter Property="Padding" Value="2" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="vm:PopupCategoryViewModel">
                    <Grid
                        Width="32"
                        Height="32"
                        ToolTipService.ToolTip="{x:Bind Title}">
                        <FontIcon
                            FontSize="18"
                            Glyph="&#xE734;"
                            Visibility="{x:Bind FavoriteIconVisibility}" />
                        <FontIcon
                            FontSize="18"
                            Glyph="&#xE81C;"
                            Visibility="{x:Bind HistoryIconVisibility}" />
                        <Image
                            Source="{x:Bind ThumbnailSource}"
                            Stretch="Uniform"
                            Visibility="{x:Bind ThumbnailVisibility}" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!--  구분선  -->
        <Border
            Grid.Row="2"
            Height="1"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!--  스티커 그리드  -->
        <GridView
            x:Name="StickerGridView"
            Grid.Row="3"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.Stickers, Mode=OneWay}"
            RightTapped="OnStickerGridViewRightTapped"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SelectionMode="None">

            <GridView.Resources>
                <TeachingTip
                    x:Name="RightClickTeachingTip"
                    Title="우클릭으로 여러 장 보내기"
                    ActionButtonClick="OnRightClickTeachingTipActionButtonClicked"
                    ActionButtonContent="확인"
                    PreferredPlacement="Top"
                    Subtitle="스티커를 우클릭하면 대기열에 추가할 수 있어요. 최대 30장까지 모아서 한번에 보낼 수 있습니다."
                    Target="{x:Bind StickerGridView}" />
                <TeachingTip
                    x:Name="EmptyPackagesTeachingTip"
                    Title="디시콘이 없어요"
                    ActionButtonClick="OnEmptyPackagesTeachingTipActionButtonClicked"
                    ActionButtonContent="디시콘 추가하기"
                    PreferredPlacement="Center"
                    Subtitle="아직 추가된 디시콘이 없습니다. 디시콘을 추가해 보세요!"
                    Target="{x:Bind StickerGridView}" />
            </GridView.Resources>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="4" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="vm:PopupStickerViewModel">
                    <Button
                        Width="80"
                        Height="80"
                        Padding="0"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        Command="{x:Bind SendCommand}"
                        CornerRadius="6"
                        ToolTipService.ToolTip="{x:Bind Title}">
                        <Grid Width="72" Height="72">
                            <Image Source="{x:Bind ImageSource}" Stretch="Uniform" />

                            <!--  즐겨찾기 토글  -->
                            <Button
                                Width="18"
                                Height="18"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{x:Bind ToggleFavoriteCommand}">
                                <Grid>
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Foreground="Black"
                                        Glyph="&#xE735;" />
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="LightGray"
                                        Glyph="&#xE735;"
                                        IsHitTestVisible="False" />
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Foreground="Gold"
                                        Glyph="&#xE735;"
                                        IsHitTestVisible="False"
                                        Visibility="{x:Bind FavoriteIconVisibility, Mode=OneWay}" />
                                </Grid>
                            </Button>
                        </Grid>
                    </Button>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!--  대기열 바  -->
        <Border
            Grid.Row="4"
            Padding="8"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            CornerRadius="4"
            Visibility="{x:Bind ViewModel.PendingBarVisibility, Mode=OneWay}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.PendingStickers}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="4" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:PendingStickerViewModel">
                                <Grid
                                    Width="36"
                                    Height="36"
                                    ToolTipService.ToolTip="{x:Bind Title}">
                                    <Image
                                        Width="32"
                                        Height="32"
                                        Source="{x:Bind ImageSource}"
                                        Stretch="Uniform" />
                                    <Button
                                        Width="14"
                                        Height="14"
                                        MinWidth="0"
                                        MinHeight="0"
                                        Padding="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Background="#C42B1C"
                                        Command="{x:Bind RemoveCommand}"
                                        CornerRadius="7">
                                        <FontIcon
                                            FontSize="8"
                                            Foreground="White"
                                            Glyph="&#xE711;" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="4">
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.PendingCountText, Mode=OneWay}" />
                    <Button
                        Click="OnSendPendingButtonClicked"
                        Content="전송"
                        Style="{ThemeResource AccentButtonStyle}" />
                    <Button Click="OnClearPendingButtonClicked" Content="초기화" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  전송 방법 토글 (단축키로 열린 경우에만 표시)  -->
        <Border
            x:Name="SendMethodToggleBorder"
            Grid.Row="5"
            Padding="8"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            CornerRadius="4"
            Visibility="Collapsed">
            <Grid>
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="전송 방법" />
                <ToggleSwitch
                    x:Name="SendMethodToggleSwitch"
                    MinWidth="0"
                    HorizontalAlignment="Right"
                    OffContent="자동"
                    OnContent="호환성"
                    Toggled="OnSendMethodToggleSwitchToggled" />
            </Grid>
        </Border>
    </Grid>
</winuiex:WindowEx>
